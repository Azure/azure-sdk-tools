{
  "servers": {
    "azure-sdk-mcp": {
      "type": "stdio",
      "command": "dotnet",
      "args": ["run", "--project", "${workspaceFolder}/tools/azsdk-cli/Azure.Sdk.Tools.Cli", "--configuration", "Debug", "--", "mcp"]
    },
    "sdk-cli": {
      "type": "stdio",
      "command": "dotnet",
      "args": ["run", "--project", "${workspaceFolder}/tools/sdk-cli/Sdk.Tools.Cli/Sdk.Tools.Cli.csproj", "--", "mcp"]
    }
  }
}

