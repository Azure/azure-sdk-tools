// Used for type-checking of TypeScript sources (run directly via Node type stripping) and the
// repo's JavaScript config files (eslint.config.js, eslint.base.config.js).
{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    // Include and type-check the JavaScript config files in this repo
    "allowJs": true,
    "checkJs": true,
    // Allow importing TypeScript sources with their `.ts` extension, as required by Node type stripping
    "allowImportingTsExtensions": true,
    // Avoid generating tsconfig.tsbuildinfo file, which isn't useful for our scenario
    "incremental": false,
    "noEmit": true,
  },
  "exclude": ["coverage"],
}
