@model APIViewWeb.Models.NamespaceApprovedEmailModel
@{
    Layout = "/EmailTemplates/_EmailLayout.cshtml";
    ViewData["EmailTitle"] = "Namespace Approved";
    ViewData["EmailPreheader"] = $"The namespace proposal for {Model.PackageName} ({Model.Language}) was approved.";
}

<p class="section">Hi Team,</p>

<p class="section">
    The namespace proposal for <strong>@Model.PackageName</strong> in <strong>@Model.Language</strong> was approved.
</p>

<div class="panel">
    <div>
        <strong>Package Name:</strong>
        @if (!string.IsNullOrWhiteSpace(Model.LanguageReviewUrl))
        {
            <a href="@Model.LanguageReviewUrl">@Model.PackageName</a>
        }
        else
        {
            @Model.PackageName
        }
    </div>
    @if (!string.IsNullOrWhiteSpace(Model.ProjectName))
    {
        <div><strong>Project Name:</strong> @Model.ProjectName</div>
    }
    <div><strong>Language:</strong> @Model.Language</div>
</div>

<div class="panel">
    <div><strong>Approved Namespace:</strong> @Model.ApprovedNamespace</div>
    <div><strong>Approved By:</strong> @Model.ApprovedBy</div>
    <div><strong>Approved On (UTC):</strong> @(Model.ApprovedOn?.ToString("u") ?? "N/A")</div>
</div>

<p class="section"><strong>Next Steps:</strong></p>
<ul class="list">
    <li>Review namespace status and history in the <a href="@Model.NamespaceTabUrl">namespace tab</a>.</li>
</ul>

<p class="section" style="margin-top: 24px;">Thanks,<br /><strong>APIView Team</strong></p>
