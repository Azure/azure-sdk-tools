{
  "name": "@azure-tools/api-review-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server.js",
    "dev": "tsx src/server.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "deploy": "tsx scripts/deploy-app.ts",
    "create-test-issue": "tsx scripts/create-test-issue.ts",
    "infra:create": "tsx scripts/infra/create-resources.ts",
    "infra:grant-github-app-key-access": "tsx scripts/infra/grant-github-app-key-access.ts",
    "infra:populate-appconfig": "tsx scripts/infra/populate-app-configuration.ts",
    "infra:check": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@azure/app-configuration": "^1.12.1",
    "@azure/arm-resources": "^6.1.0",
    "@azure/identity": "^4.10.2",
    "@azure/keyvault-keys": "^4.10.2",
    "@azure/keyvault-secrets": "^4.11.2",
    "adm-zip": "^0.5.17",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "~5.8.3"
  }
}
