# Scenario fixtures live here, one folder per scenario name
# (matching the `name:` field in the corresponding evals/*.eval.yaml).
#
# Reference them from the eval via:
#   environment:
#     files:
#       - src: ../../../fixtures/<scenario-name>/<file>   # relative to the eval file
#         dest: <path inside the workspace>
#
# (src paths resolve relative to the eval file; evals under
#  evals/workflow-scenarios/{mock,live}/ are three levels up from fixtures/.)
