GITHUB_APP_ID="123456"
WEBHOOK_SECRET="something-secret"
PRIVATE_KEY_PATH="/home/user/my-app/private-key.pem"
WEBHOOK_PROXY_URL="https://smee.io/abc123"
APPLICATIONINSIGHTS_CONNECTION_STRING="InstrumentationKey=..."

# Optional: when set, WEBHOOK_SECRET and PRIVATE_KEY_PATH are ignored and Key Vault
# is used instead. The webhook secret is read from a Key Vault secret, while the
# GitHub App JWT is signed inside Key Vault (the private key never leaves the vault).
# Locally, authenticate with Azure CLI or another DefaultAzureCredential source.
KEY_VAULT_URL="https://my-vault.vault.azure.net/"
WEBHOOK_SECRET_NAME="webhook-secret"
PRIVATE_KEY_KEY_ID="https://my-vault.vault.azure.net/keys/github-app-signing-key"
