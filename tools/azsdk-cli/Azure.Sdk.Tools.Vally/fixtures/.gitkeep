# Scenario fixtures live here, one folder per scenario name
# (matching the `name:` field in the corresponding evals/*.eval.yaml).
#
# Reference them from the eval via:
#   environment:
#     files:
#       - src: ../../fixtures/<scenario-name>/<file>      # evals/tools/*.eval.yaml (2 levels up)
#       - src: ../../../fixtures/<scenario-name>/<file>   # evals/workflow-scenarios/{mock,live}/* (3 levels up)
#         dest: <path inside the workspace>
#
# (src paths resolve relative to the eval file; adjust the number of ../ segments if the eval moves or is nested deeper.)
