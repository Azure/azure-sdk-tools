{
    "name": "update-instructions-from-pr-reviews",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.12.4",
    "description": "Skill scripts. Pure ESM TypeScript, run directly by Node ≥ 24 via built-in type stripping. No build, minimal deps.",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@eslint/js": "^9.13.0",
        "@types/node": "^24.0.0",
        "@vitest/coverage-v8": "^3.2.4",
        "eslint": "^9.13.0",
        "prettier": "^3.3.3",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.11.0",
        "vitest": "^3.2.4"
    }
}
