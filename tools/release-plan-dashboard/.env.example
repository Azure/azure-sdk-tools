# Required: GitHub App token signing (Key Vault)
KEYVAULT_NAME=
KEYVAULT_KEY_NAME=
GITHUB_APP_NUMERIC_ID=
GITHUB_INSTALL_OWNER=

# Required: GitHub OAuth App credentials
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=

# Required: Azure DevOps PAT for querying release plan work items
DEVOPS_RELEASE_PLAN_PAT=

# Optional: GitHub PAT for PR enrichment (fallback if App token minting fails)
GITHUB_PAT_RELEASE_PLAN=

# Optional: Session secret (random one is generated if not set)
SESSION_SECRET=

# Optional: Set to "production" for secure cookies
NODE_ENV=

# Optional: Base URL for OAuth redirect (defaults to https://releaseplan-dashboard.azurewebsites.net)
REDIRECT_URL=

# Optional: Comma-separated GitHub logins with PM view access
RELEASE_PLAN_DASHBOARD_PM_USERS=
