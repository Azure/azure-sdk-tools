{
    "compilerOptions": {
        "lib": ["es2016", "dom"],
        "outDir": "dist",
        "module": "commonjs",
        "sourceMap": true,
        "target": "es2016",
        "declaration": true,
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "skipLibCheck": true,
        "types": ["jest", "node"],
        "strictNullChecks": false,
        "noImplicitAny": false
    },
    "include": ["src", "test", "index.ts"]
}
