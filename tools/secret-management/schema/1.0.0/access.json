{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$id": "https://raw.githubusercontent.com/azure/azure-sdk-tools/main/tools/secret-management/schema/1.0.0/access.json",
    "title": "AccessConfiguration",
    "description": "A managed identity access configuration. Identity parameters (identityName, subscriptionId, resourceGroup) can be specified as top-level fields or within the properties dictionary.",
    "type": "object",
    "properties": {
        "identityName": {
            "type": "string",
            "description": "Name of the user-assigned managed identity. Can also be set via properties.identityName."
        },
        "subscriptionId": {
            "type": "string",
            "description": "Azure subscription ID containing the managed identity. Can also be set via properties.subscriptionId."
        },
        "resourceGroup": {
            "type": "string",
            "description": "Resource group containing the managed identity. Can also be set via properties.resourceGroup."
        },
        "location": {
            "type": "string",
            "description": "Azure location for creating a new managed identity (e.g. eastus). Required only when the identity does not yet exist."
        },
        "properties": {
            "type": "object",
            "description": "Template properties for rendering {{ variable }} placeholders in config values. Also used as fallback for identityName, subscriptionId, and resourceGroup.",
            "additionalProperties": true
        },
        "githubRepositorySecrets": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "repositories",
                    "secrets"
                ],
                "additionalProperties": false,
                "properties": {
                    "repositories": {
                        "type": "array",
                        "items": [
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "secrets": {
                        "type": "object",
                        "additionalProperties": true
                    }
                }
            }
        },
        "roleBasedAccessControls": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "role",
                    "scope"
                ],
                "additionalProperties": false,
                "properties": {
                    "role": {
                        "type": "string"
                    },
                    "scope": {
                        "type": "string"
                    }
                }
            }
        },
        "federatedIdentityCredentials": {
            "type": "array",
            "items": {
                "type": "object",
                "required": [
                    "audiences",
                    "issuer",
                    "name",
                    "subject"
                ],
                "additionalProperties": false,
                "properties": {
                    "audiences": {
                        "type": "array",
                        "items": [
                            {
                                "type": "string"
                            }
                        ]
                    },
                    "description": {
                        "type": "string"
                    },
                    "issuer": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "subject": {
                        "type": "string"
                    }
                }
            }
        }
    }
}
