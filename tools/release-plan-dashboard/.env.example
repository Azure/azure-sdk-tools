# Required: GitHub App token signing (Key Vault)
KEYVAULT_NAME=
KEYVAULT_KEY_NAME=
GITHUB_APP_NUMERIC_ID=
GITHUB_INSTALL_OWNER=

# Optional: GitHub PAT for PR enrichment (fallback if App token minting fails)
GITHUB_PAT_RELEASE_PLAN=

# Optional: Set to "production" for production deployments
NODE_ENV=

# Optional: Comma-separated user emails (Microsoft Entra) with PM view access
RELEASE_PLAN_DASHBOARD_PM_USERS=

# Optional: For local development — mock authenticated user (no Easy Auth headers needed)
DEV_AUTH_USER=
DEV_AUTH_NAME=
DEV_AUTH_OBJECT_ID=
